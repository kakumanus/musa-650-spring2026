    "y_true_all = np.array(y_true_all)\n",
    "y_pred_all = np.array(y_pred_all)\n",
    "\n",
    "# Accuracy\n",
    "ensemble_accuracy = accuracy_score(y_true_all, y_pred_all)      \n",
